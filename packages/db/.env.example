# Postgres connection string for Neon (or any Postgres reachable by @neondatabase/serverless).
# Required for drizzle-kit CLI commands run from this package (db:push, db:generate, db:migrate, db:studio).
# Locally: copy this file to .env and paste a Neon dev-branch URL.
# In Vercel: provided automatically by the Neon integration per environment.
DATABASE_URL=
